<section class="page-hero">
  <div id="ambient-canvas" class="ambient-canvas"></div>
  <div class="container page-hero-inner">
    <span class="eyebrow">Service</span>
    <div class="service-hero-row">
      <div class="service-icon service-icon-lg">
        <%- include('../partials/icons', { icon: service.icon }) %>
      </div>
      <h1><%= service.title %></h1>
    </div>
    <p><%= service.summary %></p>
    <div class="hero-actions" style="margin-top: 22px;">
      <a href="/contact" class="btn btn-primary">Get a free audit &rarr;</a>
      <a href="https://wa.me/<%= site.whatsappNumber %>" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp us</a>
    </div>
  </div>
</section>

<section>
  <div class="container service-single">
    <div>
      <h2>Overview</h2>
      <p style="color: var(--text-dim);"><%= service.description %></p>

      <%- include('../partials/video-panel', { videoTitle: service.title + ' — how it works', demoImage: '/images/demo/' + service.slug + '.svg' }) %>

      <h2>What's included</h2>
      <ul class="service-points">
        <% service.points.forEach(function(pt) { %>
          <li><%= pt %></li>
        <% }); %>
      </ul>

      <% if (service.faqs && service.faqs.length) { %>
        <h2 style="margin-top: 1.8em;"><%= service.title %> FAQs</h2>
        <div class="faq-list" style="margin-top: 22px;">
          <% service.faqs.forEach(function(f) { %>
            <details>
              <summary><%= f.q %><span class="faq-icon"></span></summary>
              <p><%= f.a %></p>
            </details>
          <% }); %>
        </div>
      <% } %>

      <div class="cta-band" style="margin-top: 44px;">
        <span class="cta-orb cta-orb-1"></span>
        <span class="cta-orb cta-orb-2"></span>
        <h2>Interested in <span class="grad-text"><%= service.title %></span>?</h2>
        <p>Get in touch and we'll walk you through how it fits your site.</p>
        <div class="cta-actions">
          <a href="/contact" class="btn btn-primary">Get in touch</a>
          <a href="https://wa.me/<%= site.whatsappNumber %>" target="_blank" rel="noopener" class="btn btn-glass">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json">
  <%- JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: service.title,
    description: service.summary,
    serviceType: service.title,
    areaServed: 'Worldwide',
    provider: {
      '@type': 'Organization',
      name: 'Contomatix',
      url: site.baseUrl
    },
    url: site.baseUrl + '/services/' + service.slug
  }) %>
</script>

<% if (service.faqs && service.faqs.length) { %>
<script type="application/ld+json">
  <%- JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: service.faqs.map(function(f) {
      return {
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a }
      };
    })
  }) %>
</script>
<% } %>
