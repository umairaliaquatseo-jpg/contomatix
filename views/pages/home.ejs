<section class="services">
  <div class="container">
    <div class="section-head centered">
      <span class="eyebrow">What we do</span>
      <h2>Six services. One goal: <span class="grad-text">rankings that hold.</span></h2>
      <p>Every service is built to compound with the others — links, content, and structure working together.</p>
    </div>
    <div class="service-grid">
      <% services.forEach(function(s) { %>
        <div class="service-card">
          <div class="service-icon">
            <%- include('../partials/icons', { icon: s.icon }) %>
          </div>
          <h3><%= s.title %></h3>
          <p><%= s.summary %></p>
          <a href="/services/<%= s.slug %>">Learn more &rarr;</a>
        </div>
      <% }); %>
    </div>
  </div>
</section>

