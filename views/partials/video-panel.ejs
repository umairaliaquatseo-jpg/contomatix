<%
var demoSrc = typeof demoImage !== 'undefined' ? demoImage : '/images/demo/link-building.svg';
%>
<div class="video-panel" data-tilt data-video>
  <div class="video-chrome">
    <span class="vc-dot"></span><span class="vc-dot"></span><span class="vc-dot"></span>
    <span class="vc-title"><%= typeof videoTitle !== 'undefined' ? videoTitle : 'How it works' %></span>
    <span class="vc-live">LIVE DEMO</span>
  </div>
  <div class="video-body">
    <img src="<%= demoSrc %>" alt="Animated walkthrough of how this service runs, from research to results" width="960" height="420">
    <button class="video-play-toggle" type="button" aria-label="Pause demo animation">
      <span class="vpt-icon">▶</span>
    </button>
  </div>
  <div class="video-controls">
    <button class="vc-play" type="button" aria-label="Play/pause demo animation">▶</button>
    <span class="vc-progress"><span class="vc-progress-fill"></span></span>
    <span class="vc-time">0:00 / 0:30</span>
  </div>
</div>
