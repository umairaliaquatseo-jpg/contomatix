<%
// Contomatix mark: a "C" ring with connected link-nodes at its opening —
// the link/network motif worked into a C monogram.
var size = typeof logoSize !== 'undefined' ? logoSize : 30;
%>
<svg viewBox="0 0 40 40" width="<%= size %>" height="<%= size %>" role="img" aria-label="Contomatix logo">
  <path d="M 28.36 10.04 A 13 13 0 1 0 28.36 29.96"
        fill="none" stroke="var(--accent-teal)" stroke-width="5" stroke-linecap="round"/>
  <line x1="28.36" y1="10.04" x2="20" y2="20" stroke="var(--border-light)" stroke-width="1.6"/>
  <line x1="28.36" y1="29.96" x2="20" y2="20" stroke="var(--border-light)" stroke-width="1.6"/>
  <circle cx="28.36" cy="10.04" r="3.6" fill="var(--accent-amber)"/>
  <circle cx="28.36" cy="29.96" r="3.6" fill="var(--accent-teal)"/>
  <circle cx="20" cy="20" r="2.4" fill="var(--text)"/>
</svg>
