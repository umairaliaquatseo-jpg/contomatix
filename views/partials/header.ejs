<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-mark" aria-hidden="true">
        <%- include('./logo', { logoSize: 30 }) %>
      </span>
      <span class="brand-name">Contomatix</span>
    </a>

    <nav class="main-nav" id="main-nav">
      <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Home</a>

      <div class="nav-dropdown">
        <button class="nav-link nav-dropdown-toggle" aria-expanded="false">
          Services
          <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
        </button>
        <div class="nav-dropdown-menu">
          <% services.forEach(function(s) { %>
            <a href="/services/<%= s.slug %>"><%= s.title %></a>
          <% }); %>
        </div>
      </div>

      <a href="/blog" class="nav-link <%= currentPath.startsWith('/blog') ? 'active' : '' %>">Blog</a>
      <a href="/team" class="nav-link <%= currentPath === '/team' ? 'active' : '' %>">Team</a>
      <a href="/about" class="nav-link <%= currentPath === '/about' ? 'active' : '' %>">About</a>
      <a href="/contact" class="nav-link nav-cta <%= currentPath === '/contact' ? 'active' : '' %>">Get in touch</a>
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
