<footer class="site-footer">
  <div class="container footer-columns">
    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        <% services.forEach(function(s) { %>
          <li><a href="/services/<%= s.slug %>"><%= s.title %></a></li>
        <% }); %>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/about">About us</a></li>
        <li><a href="/team">Team</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Resources</h4>
      <ul>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Support</a></li>
        <li><a href="/contact">Free SEO audit</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Get started</h4>
      <ul>
        <li><a href="/contact">Request an audit</a></li>
        <li><a href="https://wa.me/<%= site.whatsappNumber %>" target="_blank" rel="noopener">WhatsApp us</a></li>
        <li><a href="mailto:<%= site.contactEmail %>">Email us</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-mid">
    <div class="footer-mid-left">
      <div class="brand footer-brand">
        <span class="brand-mark" aria-hidden="true">
          <%- include('./logo', { logoSize: 30, logoId: 'logo-ftr' }) %>
        </span>
        <span class="brand-name">Conto<span class="brand-accent">matix</span></span>
      </div>
      <div class="footer-legal">
        <a href="/terms">Terms</a>
        <a href="/privacy-policy">Privacy policy</a>
        <a href="/contact">Contact</a>
      </div>
    </div>

    <div class="footer-social">
      <a href="#" aria-label="Facebook" title="Facebook">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.2-1.5 1.5-1.5h1.4V4.9c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.9V11H8v3h2.5v7h3z"/></svg>
      </a>
      <a href="#" aria-label="Instagram" title="Instagram">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="#" aria-label="LinkedIn" title="LinkedIn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M6.5 8.5H3.8V20h2.7V8.5zM5.1 3.5a1.6 1.6 0 1 0 0 3.2 1.6 1.6 0 0 0 0-3.2zM20.2 13c0-3-1.6-4.7-4-4.7-1.6 0-2.5.9-2.9 1.6V8.5h-2.7V20h2.7v-6.1c0-1.4.7-2.4 2-2.4s1.9.9 1.9 2.4V20h2.7l.3-7z"/></svg>
      </a>
      <a href="#" aria-label="X (Twitter)" title="X (Twitter)">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.7 3h3l-6.6 7.5L21.8 21h-6.1l-4.8-6.3L5.4 21h-3l7-8L2.5 3h6.2l4.3 5.7L17.7 3zm-1.1 16.2h1.7L7.8 4.7H6l10.6 14.5z"/></svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; <%= new Date().getFullYear() %> Contomatix. All rights reserved.</p>
  </div>
</footer>
