<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="canonical" href="<%= site.baseUrl %><%= currentPath === '/' ? '' : currentPath %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="<%= siteName %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:url" content="<%= site.baseUrl %><%= currentPath === '/' ? '' : currentPath %>">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
</head>
<body class="<%= pageClass %>">

  <%- include('./header') %>

  <main>
    <%- body %>
  </main>

  <%- include('./footer') %>

  <a class="whatsapp-float" href="https://wa.me/<%= site.whatsappNumber %>" target="_blank" rel="noopener" aria-label="Chat with us on WhatsApp">
    <svg viewBox="0 0 32 32" width="26" height="26" fill="currentColor" aria-hidden="true">
      <path d="M16.02 3C9.4 3 4 8.37 4 14.98c0 2.34.62 4.51 1.8 6.4L4 29l7.82-1.75a12.9 12.9 0 0 0 4.2.7h.01c6.6 0 12-5.37 12-11.98C28 8.37 22.6 3 16.02 3zm0 21.8c-1.32 0-2.6-.26-3.79-.79l-.27-.13-4.64 1.04 1.06-4.5-.17-.28a9.72 9.72 0 0 1-1.5-5.16c0-5.37 4.4-9.75 9.82-9.75 5.4 0 9.79 4.36 9.79 9.75 0 5.38-4.4 9.82-9.8 9.82zm5.36-7.34c-.29-.15-1.74-.86-2.01-.96-.27-.1-.47-.15-.66.15-.2.29-.76.96-.93 1.16-.17.2-.34.22-.63.07-.29-.15-1.23-.45-2.34-1.44-.87-.77-1.45-1.72-1.62-2.01-.17-.29-.02-.45.13-.6.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.66-1.6-.91-2.18-.24-.58-.48-.5-.66-.5-.17-.01-.37-.01-.56-.01-.2 0-.51.07-.78.37-.27.29-1.02 1-1.02 2.44s1.05 2.83 1.19 3.03c.15.2 2.06 3.15 5 4.41.7.3 1.24.48 1.67.62.7.22 1.34.19 1.84.12.56-.08 1.74-.71 1.98-1.4.24-.68.24-1.27.17-1.4-.07-.12-.27-.2-.56-.34z"/>
    </svg>
  </a>

  <div class="cookie-banner" id="cookie-banner" role="dialog" aria-label="Cookie consent" hidden>
    <p>We use cookies to run this site and understand how it's used. See our <a href="/privacy-policy">Privacy Policy</a> for details.</p>
    <div class="cookie-actions">
      <button class="btn btn-outline btn-sm" id="cookie-decline" type="button">Decline</button>
      <button class="btn btn-primary btn-sm" id="cookie-accept" type="button">Accept</button>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
