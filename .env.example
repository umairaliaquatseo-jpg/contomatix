# Copy to .env and fill in real values. On Hostinger, set these in the
# Node.js app's environment-variables panel instead of uploading a .env file.

# --- Public contact details ---
# WhatsApp number: digits only, with country code
WHATSAPP_NUMBER=923477531179
# Email address displayed on the contact page
CONTACT_EMAIL=contact@contomatix.com
# Canonical site URL (no trailing slash)
SITE_URL=https://contomatix.com

# --- Contact form email delivery (SMTP) ---
# Without these, form submissions are only logged to the server console.
# Works with any SMTP provider. Examples:
#   Gmail:     smtp.gmail.com, port 587, app password (myaccount.google.com/apppasswords)
#   Hostinger: smtp.hostinger.com, port 465, mailbox password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Where form submissions are delivered (defaults to SMTP_USER)
CONTACT_TO=umairaliaquatseo@gmail.com
# From address (defaults to SMTP_USER)
SMTP_FROM=

# PORT is read automatically if the host sets it (Hostinger does this).
